# Gradle
.gradle/
backend/.gradle/
backend/build/
backend/bin/
!backend/gradle/wrapper/gradle-wrapper.jar

# Node
node_modules/
frontend/node_modules/
frontend/dist/
# Generated from src/docs/*.md by scripts/compile-docs.js (run on every
# build/dev/start and in the Docker build) — a build artifact, not source.
frontend/src/docsCatalog.ts
# Generated from src/docs/reference/**/*.md by scripts/compile-docs.js.
frontend/src/referenceCatalog.ts
# Generated from src/docs/reference/components/**/*.md by scripts/compile-docs.js.
frontend/src/componentCatalog.ts
# Generated from the backend registries by scripts/build-doc-manifest.mjs.
frontend/src/docs/reference/function-manifest.json

# IDE
.idea/
*.iml
.vscode/
# Eclipse / Buildship (local Gradle/JDK paths leak into committed prefs)
backend/.project
backend/.settings/

# OS
.DS_Store
frontend/tsconfig.tsbuildinfo

# Claude Code
.claude/
# Multi-agent orchestration scratch (briefings, handoffs, progress notes)
.agents/

# CodeGraph local index
.codegraph/

# Playwright test screenshots and results
screenshots/
test-results/
.aider*

# Local development artifacts
sources*
parse_sources.py
# Puppeteer scratch scripts (one-off page inspection) and their screenshots
inspect.js
inspect2.js
local_screenshot.png
